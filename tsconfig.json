{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@appium/*": ["appium/*"],
      "@utils/*": ["utils/*"],
      "@tests/*": ["tests/*"],
      "@flows/*": ["flows/*"],
      "@_shared/*": ["_shared/*"],
    },

    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "tests/_shared/**/*.d.ts"]
}