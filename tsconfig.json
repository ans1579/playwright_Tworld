{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "paths": {
      "@appium/*": ["./appium/*"],
      "@tests/*": ["./tests/*"],
      "@_shared/*": ["./tests/_shared/*"]
    },
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["*.ts", "appium/**/*.ts", "tests/**/*.ts", "reporters/**/*.ts"],
  "exclude": ["node_modules", "test-output"]
}
